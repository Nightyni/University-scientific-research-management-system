    %% 定义实体和关系
    users ||--o{ projects : "领导"
    users ||--o{ project_members : "加入"
    users ||--o{ papers : "撰写"
    users ||--o{ teams : "领导" 
    users ||--o{ team_members : "加入"
    
    projects ||--o{ project_members : "包含"
    projects ||--o{ papers : "产出"
    
